# Nginx Reverse Proxy für homeport
# Einbinden in /etc/nginx/sites-available/homeport und symlink nach sites-enabled

server {
    listen 80;
    server_name homeport.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name homeport.example.com;

    # SSL (z.B. via Let's Encrypt / certbot)
    ssl_certificate     /etc/letsencrypt/live/homeport.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/homeport.example.com/privkey.pem;

    # Proxy zu homeport
    location / {
        proxy_pass         http://127.0.0.1:8855;
        proxy_http_version 1.1;
        proxy_set_header   Host             $host;
        proxy_set_header   X-Real-IP        $remote_addr;
        proxy_set_header   X-Forwarded-For  $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto https;

        # SSE (Server-Sent Events) – kein Buffering
        proxy_buffering    off;
        proxy_cache        off;
        proxy_read_timeout 3600s;
    }
}
